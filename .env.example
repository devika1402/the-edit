# Example environment for the H&M recommender.
# Copy to `.env` and fill in. `.env` is git-ignored; never commit secrets.
# Every variable here maps to a field on core.config.Settings.

# --- Google Cloud / BigQuery ------------------------------------------------
# Required: the GCP project that owns the BigQuery dataset. No default.
GCP_PROJECT=my-gcp-project

# BigQuery dataset holding raw, staging, feature, and candidate tables.
BQ_DATASET=hm_recommender

# Dataset location. The H&M data is European, so EU is the sensible default.
BQ_LOCATION=EU

# Cost guardrail: maximum_bytes_billed applied to every query (bytes). A query
# that would scan more than this fails instead of billing. Default 10 GB.
BQ_MAX_BYTES_BILLED=10000000000

# Optional: path to a service-account key, used in CI. Leave UNSET for local
# development, which uses Application Default Credentials via `make auth`.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCS bucket holding the raw CSVs. When set, ingestion loads from gs:// URIs
# (server-side, no local upload) instead of local files. Must be in the same
# region as BQ_LOCATION. Leave unset to load from local files under DATA_DIR.
GCS_BUCKET=my-bucket-hm-data
GCS_RAW_PREFIX=raw

# --- Filesystem paths -------------------------------------------------------
# Directory holding the source H&M CSVs (transactions_train, articles, customers).
DATA_DIR=data

# Directory for trained model artifacts and the saved feature list.
ARTIFACTS_DIR=artifacts

# --- Pipeline knobs (locked scoping decisions) ------------------------------
# Number of customers sampled for ranker training (D-8).
CUSTOMER_SAMPLE_SIZE=100000

# Recent-window length, in days, for the co-purchase self-join (D-6).
COPURCHASE_WINDOW_DAYS=90

# Feature as-of cutoff (D-11): features aggregate only t_dat <= this date; the
# holdout is t_dat > this date. No information from the prediction window leaks in.
FEATURE_CUTOFF_DATE=2020-09-15

# Recent-window length (days, ending at the cutoff) for feat_item popularity.
ITEM_POPULARITY_WINDOW_DAYS=30

# Retrieval: per-customer cap for each signal, and co-occurrence neighbours/article.
RETRIEVAL_TOP_N=200
RETRIEVAL_COPURCHASE_NEIGHBORS=100

# Phase 4 training: ranker sample size, negative cap, split, and CatBoost params.
TRAIN_SAMPLE_CUSTOMERS=30000
MAX_NEGATIVES_PER_CUSTOMER=50
TEST_FRACTION=0.2
RANDOM_SEED=42
RANKER_ITERATIONS=300
RANKER_LEARNING_RATE=0.1
RANKER_DEPTH=6

# Recommendation list length; MAP@12 is the primary metric (D-9).
TOP_K=12

# --- Logging ----------------------------------------------------------------
# Root log level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO
